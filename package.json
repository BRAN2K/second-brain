{
	"name": "second-brain-extraction-api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"module": "src/index.ts",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"test": "bun test",
		"test:unit": "bun test src/",
		"test:integration": "bun test test/integration",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write .",
		"db:test:up": "docker compose -f docker-compose.test.yml up -d --wait",
		"db:test:down": "docker compose -f docker-compose.test.yml down -v",
		"migrate:latest": "kysely migrate latest"
	},
	"dependencies": {
		"@sinclair/typebox": "^0.34.49",
		"ajv": "^8.20.0",
		"elysia": "^1.4.29",
		"kysely": "^0.29.2",
		"pg": "^8.22.0",
		"pino": "^10.3.1",
		"prom-client": "^15.1.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/bun": "^1.3.14",
		"@types/pg": "^8.20.0",
		"kysely-ctl": "^0.21.0",
		"typescript": "^6.0.3"
	}
}

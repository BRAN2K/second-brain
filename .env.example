# Application
APP_ENV=local        # local | prod
PORT=3000
LOG_LEVEL=info       # fatal | error | warn | info | debug | trace

# Persistence (required)
DATABASE_URL=postgres://app:app@localhost:5432/secondbrain

# LLM providers — set the key(s) for the provider(s) you want enabled. A provider is
# only "available" when its key is present, so any subset works.
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Tried in this order when no provider is forced via ?provider=
PROVIDER_ORDER=groq,openai,gemini

# Model per provider (defaults shown)
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
